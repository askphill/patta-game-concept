{
  "framework": null,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/api/leaderboard",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=30, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://pattaxnike.com https://*.pattaxnike.com https://patta.nl https://*.patta.nl https://patta.co https://*.patta.co https://ng.patta.co https://pattaclothing.us https://*.pattaclothing.us"
        }
      ]
    }
  ]
}
